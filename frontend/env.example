# Base URL of the backend API.
#
# This is a TEMPLATE. Do not put real values here.
#   - For local development: copy this file to ".env.local" and uncomment the localhost line.
#   - For production (Vercel): leave unset to use the default in src/config.js,
#     or set VITE_API_URL in the Vercel project settings.
#
# When VITE_API_URL is unset, the app falls back to the production Render URL
# defined in src/config.js.

# Local development:
# VITE_API_URL=http://localhost:8000

# Production backend (example):
# VITE_API_URL=https://blai-dwb1.onrender.com
